function ThreatRadar({ transactions, size = 200 }) {
  const { t } = useApp();
  const canvasRef = useRef(null);
  const frameRef = useRef(null);
  const angleRef = useRef(0);

  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    const W = size, H = size, cx = W/2, cy = H/2, r = W/2 - 12;

    const dots = transactions.slice(0, 30).map(() => ({
      angle: Math.random() * Math.PI * 2,
      dist: Math.random() * r * 0.88 + r * 0.06,
      score: transactions[RI(0, transactions.length)]?.score || Math.random(),
    }));

    function draw() {
      ctx.clearRect(0, 0, W, H);
      [0.25, 0.5, 0.75, 1].forEach(scale => {
        ctx.beginPath(); ctx.arc(cx, cy, r * scale, 0, Math.PI * 2);
        ctx.strokeStyle = t.border; ctx.lineWidth = 1; ctx.stroke();
      });
      ctx.strokeStyle = t.border; ctx.lineWidth = 1;
      [[cx,0,cx,H],[0,cy,W,cy]].forEach(([x1,y1,x2,y2]) => {
        ctx.beginPath(); ctx.moveTo(x1,y1); ctx.lineTo(x2,y2); ctx.stroke();
      });
      angleRef.current += 0.02;
      ctx.save(); ctx.translate(cx, cy); ctx.rotate(angleRef.current);
      const g = ctx.createLinearGradient(0, 0, r, 0);
      g.addColorStop(0, "transparent");
      g.addColorStop(0.7, t.accent + "18");
      g.addColorStop(1, t.accent + "44");
      ctx.beginPath(); ctx.moveTo(0,0); ctx.arc(0,0,r,-0.5,0); ctx.closePath();
      ctx.fillStyle = g; ctx.fill();
      ctx.beginPath(); ctx.moveTo(0,0); ctx.lineTo(r,0);
      ctx.strokeStyle = t.accent + "cc"; ctx.lineWidth = 1.5; ctx.stroke();
      ctx.restore();
      dots.forEach(d => {
        const x = cx + Math.cos(d.angle) * d.dist, y = cy + Math.sin(d.angle) * d.dist;
        const color = d.score > 0.9 ? t.danger : d.score > 0.5 ? t.amber : t.green;
        const sz = d.score > 0.85 ? 4.5 : d.score > 0.5 ? 3 : 2;
        ctx.beginPath(); ctx.arc(x, y, sz, 0, Math.PI * 2);
        ctx.fillStyle = color; ctx.fill();
        ctx.beginPath(); ctx.arc(x, y, sz + 4, 0, Math.PI * 2);
        ctx.strokeStyle = color + "55"; ctx.lineWidth = 1; ctx.stroke();
      });
      ctx.beginPath(); ctx.arc(cx, cy, 5, 0, Math.PI * 2);
      ctx.fillStyle = t.accent; ctx.fill();
      ctx.beginPath(); ctx.arc(cx, cy, 10, 0, Math.PI * 2);
      ctx.strokeStyle = t.accent + "44"; ctx.lineWidth = 1; ctx.stroke();
      frameRef.current = requestAnimationFrame(draw);
    }
    draw();
    return () => cancelAnimationFrame(frameRef.current);
  }, [transactions.length, t.accent, size]);

  return <canvas ref={canvasRef} width={size} height={size} style={{ display: "block" }} />;
}

