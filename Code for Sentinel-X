const TX_CONFIG = {
  APPROVE_THRESHOLD: 0.49, STEPUP_THRESHOLD: 0.79, FLAG_THRESHOLD: 0.89,
  W_ML: 0.35, W_GEO: 0.30, W_DEVICE: 0.20, W_BIOMETRIC: 0.15,
  VELOCITY_ALERT: 5, MAX_SPEED_KMH: 900, EARTH_RADIUS_KM: 6371,
  MIN_HUMAN_TYPING: 0.5, MAX_HUMAN_TYPING: 10.0,
};
const userBaselinesStore = {};
const userTxCountsStore = {};

function txMlScore(tx) {
  const t0 = performance.now();
  let score = 0; const factors = [];
  const baseline = userBaselinesStore[tx.userId] || { avgAmount: 500 };
  const amountRatio = tx.amount / (baseline.avgAmount || 500);
  if (amountRatio > 5) { score += 0.35; factors.push("extreme_amount"); }
  else if (amountRatio > 3) { score += 0.25; factors.push("high_amount"); }
  else if (amountRatio > 2) { score += 0.12; factors.push("elevated_amount"); }
  const hour = new Date().getHours();
  if (hour >= 0 && hour < 5) { score += 0.15; factors.push("unusual_hour"); }
  if (tx.transactionFrequencyLast5Min > 8) { score += 0.2; factors.push("extreme_frequency"); }
  else if (tx.transactionFrequencyLast5Min > 5) { score += 0.12; factors.push("high_frequency"); }
  if (tx.ipAddress && (tx.ipAddress.startsWith("10.") || tx.ipAddress.includes("tor"))) {
    score += 0.1; factors.push("suspicious_ip");
  }
  score += (Math.random() * 0.08 - 0.04);
  score = Math.max(0, Math.min(1, score));
  const inferenceMs = performance.now() - t0;
  const explanation = factors.length > 0
    ? `ML detected ${factors.length} anomaly signal(s): ${factors.join(", ")}. Amount ratio: ${amountRatio.toFixed(1)}x baseline.`
    : "No significant anomalies detected by Isolation Forest model.";
  return { riskScore: score, anomalyFactors: factors, explanation, inferenceMs };
}

function parseGeoCoord(s) {
  if (!s) return null;
  const p = s.split(",").map(Number);
  return (p.length === 2 && !isNaN(p[0]) && !isNaN(p[1])) ? p : null;
}

function haversineKm(lat1, lon1, lat2, lon2) {
  const toRad = d => d * Math.PI / 180;
  const dLat = toRad(lat2 - lat1), dLon = toRad(lon2 - lon1);
  const a = Math.sin(dLat/2)**2 + Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon/2)**2;
  return TX_CONFIG.EARTH_RADIUS_KM * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
}

function txComputeGeoVelocity(currentGeo, baseline) {
  const lastGeo = baseline.lastGeoLocation || "";
  const lastTime = baseline.lastTransactionTime || 0;
  if (!lastGeo || !lastTime) return 0.1;
  const curr = parseGeoCoord(currentGeo), prev = parseGeoCoord(lastGeo);
  if (!curr || !prev) return 0.2;
  const dist = haversineKm(prev[0], prev[1], curr[0], curr[1]);
  const hours = (Date.now() - lastTime) / 3600000;
  if (hours < 0.001) return dist > 1 ? 0.95 : 0.0;
  const speed = dist / hours;
  if (speed > TX_CONFIG.MAX_SPEED_KMH) return Math.min(1, 0.7 + (speed - TX_CONFIG.MAX_SPEED_KMH) / 5000);
  if (speed > 500) return 0.4;
  if (speed > 200) return 0.2;
  return 0.0;
}

function txComputeDeviceScore(deviceId, baseline) {
  const known = baseline.knownDevices || [];
  if (!known.length) return 0.3;
  return known.includes(deviceId) ? 0.0 : 0.65;
}

function txComputeBiometricScore(typingSpeed, scrollPattern) {
  let typingRisk = 0;
  if (typingSpeed === 0) typingRisk = 0.4;
  else if (typingSpeed < TX_CONFIG.MIN_HUMAN_TYPING) typingRisk = 0.3;
  else if (typingSpeed > TX_CONFIG.MAX_HUMAN_TYPING) typingRisk = 0.8;
  let scrollRisk = 0;
  if (scrollPattern < 0.1) scrollRisk = 0.7;
  else if (scrollPattern < 0.3) scrollRisk = 0.4;
  return typingRisk * 0.6 + scrollRisk * 0.4;
}

function txDecide(tx) {
  const t0 = performance.now();
  const baseline = userBaselinesStore[tx.userId] || { avgAmount: 500, knownDevices: [], lastGeoLocation: "", lastTransactionTime: 0 };
  const ml = txMlScore(tx);
  const geoScore = txComputeGeoVelocity(tx.geoLocation, baseline);
  const deviceScore = txComputeDeviceScore(tx.deviceId, baseline);
  const biometricScore = txComputeBiometricScore(tx.typingSpeed, tx.scrollPattern);
  const txCount = (userTxCountsStore[tx.userId] || 0) + tx.transactionFrequencyLast5Min;
  let composite = ml.riskScore * TX_CONFIG.W_ML + geoScore * TX_CONFIG.W_GEO + deviceScore * TX_CONFIG.W_DEVICE + biometricScore * TX_CONFIG.W_BIOMETRIC;
  if (txCount > TX_CONFIG.VELOCITY_ALERT) composite += Math.min(0.3, (txCount - TX_CONFIG.VELOCITY_ALERT) * 0.05);
  composite = Math.max(0, Math.min(1, composite));
  let decision = "PASSED";
  if (composite > TX_CONFIG.FLAG_THRESHOLD) decision = "KILLED";
  else if (composite > TX_CONFIG.STEPUP_THRESHOLD) decision = "FLAGGED";
  else if (composite > TX_CONFIG.APPROVE_THRESHOLD) decision = "STEP_UP";
  // Update baseline
  userBaselinesStore[tx.userId] = {
    avgAmount: baseline.avgAmount * 0.9 + tx.amount * 0.1,
    knownDevices: [...new Set([...(baseline.knownDevices || []), tx.deviceId])].slice(-5),
    lastGeoLocation: tx.geoLocation,
    lastTransactionTime: Date.now(),
  };
  userTxCountsStore[tx.userId] = (userTxCountsStore[tx.userId] || 0) + 1;
  const processingTimeMs = performance.now() - t0;
  return {
    txId: `TX-${Date.now()}-${Math.floor(Math.random()*9000+1000)}`,
    decision, compositeScore: composite,
    breakdown: { ml: ml.riskScore, geo: geoScore, device: deviceScore, biometric: biometricScore },
    anomalyFactors: ml.anomalyFactors, explanation: ml.explanation, processingTimeMs,
  };
}

