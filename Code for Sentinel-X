const AppContext = createContext(null);
const useApp = () => useContext(AppContext);

const R = (a, b) => Math.random() * (b - a) + a;
const RI = (a, b) => Math.floor(R(a, b));
const pick = a => a[RI(0, a.length)];

const MERCHANTS = ["Swiggy","Amazon.in","Zomato","Flipkart","Paytm Mall","BookMyShow","Ola","MakeMyTrip","Netflix","Steam","Unknown Vendor","Offshore TXN","Crypto Exchange","Dark Web Ref"];
const CITIES = ["Bangalore","Mumbai","Delhi","Chennai","Hyderabad","Pune","Kolkata","London","Dubai","Singapore","Moscow","Lagos"];
const METHODS = ["UPI","IMPS","NEFT","RTGS","Debit Card","Credit Card"];
const USERS = ["USR-4821","USR-2294","USR-5507","USR-3312","USR-9901","USR-6673","USR-1148","USR-7734","USR-0092"];
const ALL_FLAGS = ["GEO_VELOCITY","VPN_DETECTED","DEVICE_MISMATCH","VELOCITY_BREACH","FOREIGN_ORIGIN","UNUSUAL_HOUR","NEW_MERCHANT","SALAMI_PATTERN","IP_BLACKLIST","BIOMETRIC_FAIL","SESSION_HIJACK","CARD_TESTING"];

const fmt = n => new Intl.NumberFormat("en-IN", { style: "currency", currency: "INR", maximumFractionDigits: 0 }).format(n);

function genTx(id) {
  const score = parseFloat(R(0, 1).toFixed(4));
  const risky = score > 0.5;
  const amount = risky ? RI(8000, 180000) : RI(50, 15000);
  const city = score > 0.82 ? pick(["London","Dubai","Singapore","Moscow","Lagos"]) : pick(["Bangalore","Mumbai","Delhi","Chennai","Hyderabad"]);
  const status = score < 0.5 ? "PASSED" : score < 0.8 ? "STEP_UP" : score < 0.9 ? "FLAGGED" : "KILLED";
  const numFlags = score > 0.9 ? RI(3, 6) : score > 0.7 ? RI(1, 3) : score > 0.5 ? RI(0, 2) : 0;
  const flags = score < 0.5 ? [] : ALL_FLAGS.slice().sort(() => R(-1,1)).slice(0, numFlags);
  const l1 = RI(6, 22), l2 = RI(38, 98), l3 = RI(12, 55);
  return {
    id: id || `TX-${Date.now()}-${RI(1000,9999)}`,
    user: pick(USERS),
    merchant: score > 0.82 ? pick(["Unknown Vendor","Offshore TXN","Crypto Exchange","Dark Web Ref"]) : pick(MERCHANTS),
    amount, method: pick(METHODS), city, score, status,
    time: new Date().toLocaleTimeString("en-US", { hour12: false }),
    timestamp: Date.now(),
    flags, l1, l2, l3,
    total: l1 + l2 + l3,
  };
}

