                  <div style={{ textAlign: "right" }}>
                    <div style={{ fontSize: 11, color: t.textMuted, marginBottom: 2 }}>COMPOSITE RISK SCORE</div>
                    <div className="mono" style={{ fontSize: 26, fontWeight: 700, color: d.color }}>{result.compositeScore.toFixed(4)}</div>
                    <div style={{ fontSize: 10, color: t.textMuted, marginTop: 2 }}>Latency: {result.processingTimeMs.toFixed(2)}ms</div>
                  </div>
                </div>
                {/* Score Breakdown */}
                <div className="glass-panel" style={{ padding: 16 }}>
                  <div style={{ fontSize: 12, fontWeight: 600, color: t.text, marginBottom: 12 }}>Score Breakdown</div>
                  {[["ML Isolation Forest", result.breakdown.ml, t.accent], ["Geo-Velocity", result.breakdown.geo, t.violet], ["Device Fingerprint", result.breakdown.device, t.amber], ["Behavioral Biometrics", result.breakdown.biometric, t.green]].map(([lbl, val, col]) => (
                    <div key={lbl} style={{ display: "flex", alignItems: "center", justifyContent: "space-between", padding: "8px 0", borderBottom: `1px solid ${t.border}` }}>
                      <span style={{ fontSize: 12, color: t.textSub }}>{lbl}</span>
                      <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
                        <div style={{ width: 80, height: 5, background: t.border, borderRadius: 3, overflow: "hidden" }}>
                          <div style={{ height: "100%", width: `${val*100}%`, background: col, borderRadius: 3, transition: "width 0.5s ease" }} />
                        </div>
                        <span className="mono" style={{ fontSize: 11, color: col, minWidth: 40, textAlign: "right" }}>{val.toFixed(3)}</span>
                      </div>
                    </div>
                  ))}
                </div>
                {/* Explanation & Flags */}
                <div className="glass-panel" style={{ padding: 16 }}>
                  <div style={{ fontSize: 12, fontWeight: 600, color: t.text, marginBottom: 8 }}>ML Explanation</div>
                  <div style={{ fontSize: 12, color: t.textSub, lineHeight: 1.7, background: t.surface, borderRadius: 8, padding: "10px 12px", border: `1px solid ${t.border}` }}>{result.explanation}</div>
                  {result.anomalyFactors.length > 0 && (
                    <div style={{ marginTop: 10, display: "flex", flexWrap: "wrap", gap: 6 }}>
                      {result.anomalyFactors.map(f => <span key={f} className="tag" style={{ color: t.amber, borderColor: t.amber + "44" }}>{f}</span>)}
                    </div>
                  )}
                </div>
                <div style={{ fontSize: 10, color: t.textMuted, textAlign: "right" }} className="mono">TX ID: {result.txId}</div>
              </div>
            );
          })()}
        </div>
      </div>
    </div>
  );
}

const NAV_ITEMS = [
  { id: "dashboard", icon: "⊞", label: "Dashboard" },
  { id: "stream", icon: "⚡", label: "Live Stream" },
  { id: "submit", icon: "🔍", label: "Submit Tx" },
  { id: "threat", icon: "🎯", label: "Threat Analysis" },
  { id: "biometrics", icon: "🔬", label: "Biometrics" },
  { id: "pipeline", icon: "🏗️", label: "Pipeline" },
  { id: "flags", icon: "🚩", label: "Anomaly Flags" },
  { id: "xai", icon: "📋", label: "XAI Reports" },
];

function Sidebar({ view, navigate, collapsed, setCollapsed }) {
  const { t, transactions } = useApp();
  const killed = transactions.filter(x => x.status === "KILLED").length;

  return (
    <div style={{ width: collapsed ? 56 : 216, flexShrink: 0, display: "flex", flexDirection: "column", background: t.sidebarBg, borderRight: `1px solid ${t.border}`, transition: "width 0.25s cubic-bezier(0.22,1,0.36,1)", overflow: "hidden", backdropFilter: "blur(20px)", position: "relative", zIndex: 10 }}>
      <div style={{ padding: collapsed ? "18px 10px" : "18px 16px", borderBottom: `1px solid ${t.border}`, display: "flex", alignItems: "center", gap: 10, overflow: "hidden" }}>
        <div style={{ width: 32, height: 32, borderRadius: 8, background: t.accentSoft, border: `1px solid ${t.borderAccent}`, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 14, fontWeight: 800, color: t.accent, flexShrink: 0 }}>SX</div>
        {!collapsed && (
          <div style={{ overflow: "hidden" }}>
            <div style={{ fontSize: 14, fontWeight: 800, color: t.accent === "#2563eb" ? t.text : t.accent, letterSpacing: "0.02em", whiteSpace: "nowrap" }}>Sentinel-X</div>
            <div style={{ fontSize: 10, color: t.textMuted, whiteSpace: "nowrap" }}>Fraud Prevention Engine</div>
          </div>
        )}
      </div>
      <div style={{ flex: 1, padding: "10px 8px", overflowY: "auto", overflowX: "hidden" }}>
        {!collapsed && <div style={{ fontSize: 10, fontWeight: 600, color: t.textMuted, letterSpacing: "0.08em", padding: "4px 8px 8px", textTransform: "uppercase" }}>Navigation</div>}
        {NAV_ITEMS.map(item => (
          <div key={item.id} className={`nav-item ${view === item.id ? "active" : ""}`}
            onClick={() => navigate(item.id)}
            style={{ justifyContent: collapsed ? "center" : "flex-start", padding: collapsed ? "9px" : "9px 12px", marginBottom: 2 }}
            title={collapsed ? item.label : undefined}>
            <span style={{ fontSize: 17, flexShrink: 0 }}>{item.icon}</span>
            {!collapsed && <span style={{ overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>{item.label}</span>}
            {!collapsed && item.id === "xai" && killed > 0 && (
              <span style={{ marginLeft: "auto", minWidth: 18, height: 18, borderRadius: 9, background: t.danger, color: "#fff", fontSize: 10, display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 700 }}>{killed}</span>
            )}
          </div>
        ))}
      </div>
      <div style={{ padding: "10px 8px", borderTop: `1px solid ${t.border}` }}>
        <div className="nav-item" onClick={() => setCollapsed(c => !c)} style={{ justifyContent: collapsed ? "center" : "flex-start", padding: collapsed ? "9px" : "9px 12px" }}>
          <span style={{ fontSize: 16 }}>{collapsed ? "→" : "←"}</span>
          {!collapsed && <span>Collapse</span>}
        </div>
      </div>
    </div>
  );
}

function Header({ view, navigate, theme, setTheme }) {
  const { t, transactions, simRunning } = useApp();
  const [time, setTime] = useState("");
  useEffect(() => {
    const tick = () => setTime(new Date().toLocaleTimeString("en-US", { hour12: false }));
    tick(); const id = setInterval(tick, 1000);
    return () => clearInterval(id);
  }, []);

  const killed = transactions.filter(x => x.status === "KILLED").length;
  const labels = { dashboard: "Overview", stream: "Live Stream", threat: "Threat Analysis", biometrics: "Behavioral Biometrics", pipeline: "Three-Layer Pipeline", flags: "Anomaly Flags", xai: "XAI Reports", total: "Transactions", killed: "Kill Events", stepup: "Step-Up Events", passed: "Passed Events", avgrisk: "Risk Analytics", speed: "Speed Analytics" };

  return (
    <div style={{ height: 56, flexShrink: 0, display: "flex", alignItems: "center", padding: "0 20px", gap: 16, background: t.headerBg, borderBottom: `1px solid ${t.border}`, backdropFilter: "blur(20px)", zIndex: 9 }}>
      <div style={{ display: "flex", alignItems: "center", gap: 8, flex: 1 }}>
        {view !== "dashboard" && (
          <>
            <button className="btn-base btn-ghost" style={{ padding: "4px 10px", fontSize: 12 }} onClick={() => navigate("dashboard")}>← Dashboard</button>
            <span style={{ color: t.textMuted }}>·</span>
          </>
        )}
        <span style={{ fontSize: 14, fontWeight: 600, color: t.text }}>{labels[view] || "Dashboard"}</span>
      </div>
      <div style={{ display: "flex", gap: 12, alignItems: "center" }}>
        {[{ label: "SYSTEM", val: "ONLINE", color: t.green }, { label: "ML", val: "ACTIVE", color: t.accent }, { label: "REDIS", val: "HOT", color: t.violet }].map(s => (
          <div key={s.label} style={{ display: "flex", alignItems: "center", gap: 5, fontSize: 11 }}>
            <div style={{ width: 5, height: 5, borderRadius: "50%", background: s.color, animation: "pulse 2s infinite" }} />
            <span style={{ color: t.textMuted }}>{s.label}:</span>
            <span style={{ color: s.color, fontWeight: 600 }}>{s.val}</span>
          </div>
        ))}
        {killed > 0 && (
          <div style={{ display: "flex", alignItems: "center", gap: 6, padding: "3px 10px", borderRadius: 6, background: t.danger + "18", border: `1px solid ${t.danger}33`, cursor: "pointer" }} onClick={() => navigate("killed")}>
            <span style={{ fontSize: 12 }}>⛔</span>
            <span style={{ fontSize: 11, color: t.danger, fontWeight: 600 }}>{killed} killed</span>
          </div>
        )}
        <span className="mono" style={{ fontSize: 11, color: t.textMuted, letterSpacing: "0.06em" }}>
          {time}<span style={{ animation: "blink 1s step-end infinite" }}>_</span>
        </span>
        <select value={theme} onChange={e => setTheme(e.target.value)} style={{ fontSize: 11, padding: "4px 8px", minWidth: 100 }}>
          <option value="cyber">🌐 Cyber</option>
          <option value="graphite">⬛ Graphite</option>
          <option value="soc">☀️ SOC Light</option>
        </select>
      </div>
    </div>
  );
}

export default function SentinelXApp() {
  const [theme, setTheme] = useState("cyber");
  const t = THEMES[theme];

  const [transactions, setTransactions] = useState(() => Array.from({ length: 16 }, () => genTx()));
  const [simRunning, setSimRunning] = useState(true);
  const [view, setView] = useState("dashboard");
  const [collapsed, setCollapsed] = useState(false);
  const intervalRef = useRef(null);

  const navigate = useCallback((v) => setView(v), []);

  const addTx = useCallback(() => {
    setTransactions(prev => [genTx(), ...prev.slice(0, 79)]);
  }, []);

  useEffect(() => {
    if (simRunning) { intervalRef.current = setInterval(addTx, 1100); }
    else clearInterval(intervalRef.current);
    return () => clearInterval(intervalRef.current);
  }, [simRunning, addTx]);

  const ctx = useMemo(() => ({ t, transactions, simRunning, setSimRunning }), [t, transactions, simRunning]);

  const renderView = () => {
    const statViews = ["total","killed","stepup","passed","avgrisk","speed"];
    if (statViews.includes(view)) return <StatsDetailView onBack={() => navigate("dashboard")} type={view} />;
    switch (view) {
      case "stream":     return <LiveStreamView onBack={() => navigate("dashboard")} />;
      case "submit":     return <SubmitTransactionView onBack={() => navigate("dashboard")} />;
      case "threat":     return <ThreatAnalysisView onBack={() => navigate("dashboard")} />;
      case "biometrics": return <BiometricsView onBack={() => navigate("dashboard")} />;
      case "pipeline":   return <PipelineView onBack={() => navigate("dashboard")} />;
      case "xai":        return <XAIReportView onBack={() => navigate("dashboard")} />;
      case "flags":      return <AnomalyFlagsView onBack={() => navigate("dashboard")} />;
      default:           return <Dashboard navigate={navigate} />;
    }
  };

  return (
    <AppContext.Provider value={ctx}>
      <GlobalStyles t={t} />
      <div style={{ position: "fixed", inset: 0, zIndex: 0, pointerEvents: "none",
        backgroundImage: `radial-gradient(ellipse 80% 50% at 20% 0%, ${t.accentGlow} 0%, transparent 60%), radial-gradient(ellipse 60% 40% at 80% 100%, ${t.violetSoft} 0%, transparent 60%)` }} />
      <div style={{ position: "fixed", inset: 0, zIndex: 0, pointerEvents: "none",
        backgroundImage: `linear-gradient(${t.gridLine} 1px, transparent 1px), linear-gradient(90deg, ${t.gridLine} 1px, transparent 1px)`,
        backgroundSize: "40px 40px",
        maskImage: "radial-gradient(ellipse 100% 100% at 50% 0%, black 40%, transparent 100%)" }} />
      <div style={{ position: "relative", zIndex: 1, display: "flex", flexDirection: "column", height: "100vh" }}>
        <Header view={view} navigate={navigate} theme={theme} setTheme={setTheme} />
        <div style={{ flex: 1, display: "flex", overflow: "hidden" }}>
          <Sidebar view={view} navigate={navigate} collapsed={collapsed} setCollapsed={setCollapsed} />
          <main style={{ flex: 1, overflowY: "auto", padding: "20px 24px" }}>
            {renderView()}
          </main>
        </div>
      </div>
    </AppContext.Provider>
  );
}
